{
  "permissions": {
    "allow": [
      "Bash(./bin/mise *)",
      "Bash(git *)",
      "Bash(jq *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '\\.dart$' && ./bin/mise run --no-deps dart:format >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [".mise"]
  }
}
